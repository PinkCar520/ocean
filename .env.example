# 内网 Qwen/MiniMax 等私有化模型的 Base URL (需兼容 OpenAI API 标准体例)
# 如果是 vLLM 部署，形如 HTTP://10.10.0.1:8000/v1
VLLM_API_BASE=http://localhost:8000/v1
VLLM_API_KEY=YOUR_SUPER_SECRET_KEY
VLLM_MODEL_NAME=qwen2.5-coder:7b,deepseek-v3,qwen3.5-omni-flash

# 阿里百炼 (DashScope) 模型配置
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_KEY

# Gateway 服务启动端口
PORT=3000

# 禅道集成配置 (ZenTao Integration)
# 例如: http://zentao.your-bank.com
ZENTAO_BASE_URL=
# 禅道 API Token 或 用户名:密码 的 Base64
ZENTAO_API_TOKEN=

# Jenkins CI/CD 集成配置
# Docker 部署默认地址: http://jenkins:8080
JENKINS_BASE_URL=http://jenkins:8080
# Jenkins API Token (在用户设置中生成)
JENKINS_TOKEN=

# GitLab 代码托管集成配置
# Docker 部署默认地址: http://gitlab:80
GITLAB_BASE_URL=http://gitlab:80
# GitLab Personal Access Token (需 api, read_user 权限)
GITLAB_TOKEN=
