# ==========================================
# 默认模型提供商设置 (用来决定系统默认使用哪个)
# ==========================================
DEFAULT_AI_PROVIDER=deepseek    # 可选: deepseek, claude, gemini, dashscope, openai, local

# ==========================================
# 1. DeepSeek 配置
# ==========================================
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=

# ==========================================
# 2. Anthropic (Claude) 配置
# ==========================================
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY
ANTHROPIC_MODEL=

# ==========================================
# 3. Google Gemini 配置
# ==========================================
GEMINI_API_KEY=YOUR_GEMINI_KEY
GEMINI_MODEL=

# ==========================================
# 4. 阿里百炼 (DashScope) 配置
# ==========================================
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_KEY
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=

# ==========================================
# 5. OpenAI 官方配置
# ==========================================
OPENAI_API_KEY=YOUR_OPENAI_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=

# ==========================================
# 6. 本地私有化模型 (vLLM / Ollama)
# ==========================================
LOCAL_API_KEY=ollama
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=
# Gateway 服务启动端口
PORT=3000

# 禅道集成配置 (ZenTao Integration)
# 例如: http://zentao.your-bank.com
ZENTAO_BASE_URL=
# 禅道 API Token 或 用户名:密码 的 Base64
ZENTAO_API_TOKEN=

# Jenkins CI/CD 集成配置
# Docker 部署默认地址: http://jenkins:8080
JENKINS_BASE_URL=http://jenkins:8080
# Jenkins API Token (在用户设置中生成)
JENKINS_TOKEN=

# GitLab 代码托管集成配置
# Docker 部署默认地址: http://gitlab:80
GITLAB_BASE_URL=http://gitlab:80
# GitLab Personal Access Token (需 api, read_user 权限)
GITLAB_TOKEN=
